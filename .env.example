# ─── Backend (required) ─────────────────────────────────────────────────────
# Primary AI engine. ClearScript uses OpenAI gpt-5.4-mini via the official
# openai SDK for contract parsing, disclosure analysis, and audit letter
# generation. Without this key, AI endpoints fall back to mock data.
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── Backend (optional) ─────────────────────────────────────────────────────
# Only needed if you run the RocketRide multi-stage pipeline engine locally.
# The default fallback path routes contract analysis through OpenAI, so this
# is safe to leave unset in dev and production.
GEMINI_API_KEY=
ROCKETRIDE_URI=ws://localhost:5565

# Comma-separated list of allowed frontend origins for CORS.
# Add your Vercel production URL here before deploying.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ─── Frontend (required) ────────────────────────────────────────────────────
# Clerk auth — get these from https://dashboard.clerk.com after creating an
# application. Both must be set or the frontend will fail to build.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Backend URL the Next.js frontend talks to. Leave as localhost if running the
# backend locally; point at your Render URL if you only want to run the
# frontend against deployed data.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Clerk route config — these match the production Vercel setup.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
